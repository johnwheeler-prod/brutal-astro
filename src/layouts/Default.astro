---
import BaseNavigation from '@components/layout/BaseNavigation.astro';
import BaseFooter from '@components/layout/BaseFooter.astro';
import BaseHead from '../components/layout/BaseHead.astro';

interface Props {
  title: string;
  description: string;
  classList?: string;
  pageTitle?: string;
  ogImage?: URL;
  ogType?: string;
  pageSchema?: Record<string, any>;
  breadcrumbs?: Array<{name: string, url: string}>;
  customTitle?: string;
  isHomepage?: boolean;
  isBlogIndex?: boolean;
  blogPosts?: Array<{title: string, description: string, url: string, pubDate: string, author?: string}>;
  isTagPage?: boolean;
  tagName?: string;
  articleBody?: string;
}

const { title, description, classList, ogImage, ogType, pageSchema, breadcrumbs, customTitle, isHomepage = false, isBlogIndex = false, blogPosts = [], isTagPage = false, tagName, articleBody } = Astro.props;
const pageTitle = Astro.props.pageTitle ?? `John Wheeler | ${title}`;
---

<html lang='en' class='h-full'>
  <BaseHead ogImage={ogImage} ogType={ogType} title={title} description={description} pageSchema={pageSchema} breadcrumbs={breadcrumbs} customTitle={customTitle} isHomepage={isHomepage} isBlogIndex={isBlogIndex} blogPosts={blogPosts} isTagPage={isTagPage} tagName={tagName} articleBody={articleBody}/>

  <body class:list={[classList]}>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5DFDJZF8"
      height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <BaseNavigation {pageTitle} />
    <slot />
    <BaseFooter />
    
    <!-- Load global CSS after initial render -->
    <script is:inline>
      // Ensure global styles are loaded for non-critical elements
      if (!document.querySelector('link[href="/styles/global.css"]')) {
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = '/styles/global.css';
        document.head.appendChild(link);
      }
    </script>
  </body>
</html>