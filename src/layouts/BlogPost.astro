---
import Layout from './Default.astro';
import BlogSideBar from '@components/blog/BlogSideBar.astro';
import BlogContent from '@components/blog/BlogContent.astro';
import RecentBlogPosts from '@components/generic/RecentBlogPosts.astro';

const ogImage = new URL(`/v1/generate/og/${Astro.params.slug}.png`, Astro.url);

const { content, headings } = Astro.props;
const { title, description, pubDate, updatedDate, image, author = "John Wheeler" } = content;

const siteUrl = 'https://www.johnwheelerproduction.com';
const url = `${siteUrl}${Astro.url.pathname}`;

// Generate optimized titles based on slug
let optimizedTitle;
switch(Astro.params.slug) {
  case '1-answer-engine-obscurity':
    optimizedTitle = 'Answer Engine Obscurity: Simple UI Holding Back AEO | John Wheeler';
    break;
  case '2-seo-for-small-business':
    optimizedTitle = 'SEO for Small Business Owners: Complete Guide to Get Found Online';
    break;
  case '3-openai-google-feuding':
    optimizedTitle = 'Google vs OpenAI: The AI Search War Explained | John Wheeler';
    break;
  case '4-a-double-edged-skill':
    optimizedTitle = 'AI in Hiring: The Resume Filtering Paradox';
    break;
  default:
    optimizedTitle = title;
}

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "url": url,
  "datePublished": pubDate,
  "dateModified": updatedDate || pubDate,
  "author": {
    "@type": "Person",
    "name": author,
    "url": siteUrl
  },
  "publisher": {
    "@type": "Organization",
    "name": "John Wheeler Production",
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/logo.svg`
    }
  },
  "image": `${siteUrl}${image || ogImage}`,
  "description": description,
  "mainEntityOfPage": url
};
---

<Layout
  title={optimizedTitle as string}
  description={description as string}
  ogImage={ogImage}
  ogType='article'
  pageSchema={pageSchema}
  includeAuthorInTitle={false}
>
  <main class='p-6 lg:grid lg:grid-cols-3 flex justify-center'>
    <BlogSideBar headings={headings} />
    <BlogContent content={content}>
      <slot />
    </BlogContent>
  </main>
  <section class='p-6'>
    <RecentBlogPosts count={6} />
  </section>
</Layout>