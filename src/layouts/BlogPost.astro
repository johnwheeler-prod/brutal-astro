---
import Layout from './Default.astro';
import BlogSideBar from '@components/blog/BlogSideBar.astro';
import BlogContent from '@components/blog/BlogContent.astro';
import RecentBlogPosts from '@components/generic/RecentBlogPosts.astro';

const ogImage = new URL(`/v1/generate/og/${Astro.params.slug}.png`, Astro.url);

const { content, headings } = Astro.props;
const { title, description, pubDate, updatedDate, image, author = "John Wheeler" } = content;

const siteUrl = 'https://www.johnwheelerproduction.com';
const url = `${siteUrl}${Astro.url.pathname}`;

// Custom title logic for specific posts
let customTitle;
if (Astro.params.slug === '1-answer-engine-obscurity') {
  customTitle = 'Answer Engine Obscurity: Simple UI Holding Back AEO | John Wheeler';
} else if (Astro.params.slug === '2-seo-for-small-business') {
  customTitle = 'SEO for Small Business Owners: Complete Guide to Get Found Online';
} else if (Astro.params.slug === '3-openai-google-feuding') {
  customTitle = 'Google vs OpenAI: The AI Search War Explained | John Wheeler';
} else if (Astro.params.slug === '4-a-double-edged-skill') {
  customTitle = 'AI in Hiring: The Resume Filtering Paradox';
}

const pageSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "url": url,
  "datePublished": pubDate,
  "dateModified": updatedDate || pubDate,
  "author": {
    "@type": "Person",
    "name": author,
    "url": siteUrl
  },
  "publisher": {
    "@type": "Organization",
    "name": "John Wheeler Production",
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/logo.svg`
    }
  },
  "image": `${siteUrl}${image || ogImage}`,
  "description": description,
  "mainEntityOfPage": url
};
---

<Layout
  title={title as string}
  description={description as string}
  ogImage={ogImage}
  ogType='article'
  pageSchema={pageSchema}
  customTitle={customTitle}
>
  <main class='p-6 lg:grid lg:grid-cols-3 flex justify-center'>
    <BlogSideBar headings={headings} />
    <BlogContent content={content}>
      <slot />
    </BlogContent>
  </main>
  <section class='p-6'>
    <RecentBlogPosts count={6} />
  </section>
</Layout>