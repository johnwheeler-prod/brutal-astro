---
import LocalFont from '../generic/LocalFont.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: URL;
  ogType?: string;
  pageSchema?: Record<string, any>;
  breadcrumbs?: Array<{name: string, url: string}>;
  faqSchema?: Record<string, any>;
  collectionSchema?: Record<string, any>;
  isHomepage?: boolean;
  customTitle?: string;
  isBlogIndex?: boolean;
  blogPosts?: Array<{title: string, description: string, url: string, pubDate: string, author?: string}>;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

if (Astro.props.ogImage === undefined) {
  Astro.props.ogImage = new URL('/v1/generate/og/default.png', Astro.url);
}

const { title, description, ogImage, ogType = 'website', pageSchema, breadcrumbs, faqSchema, collectionSchema, isHomepage = false, customTitle, isBlogIndex = false, blogPosts = [] } = Astro.props;

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "John Wheeler",
  "url": "https://www.johnwheelerproduction.com/",
  "jobTitle": "Software and Web Engineer",
  "sameAs": [
    "https://www.linkedin.com/in/john-wheeler-5697431b9/",
    "https://github.com/johnwheeler"
  ]
};

// Enhanced Person schema for homepage
const enhancedPersonSchema = isHomepage ? {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "John Wheeler",
  "url": "https://www.johnwheelerproduction.com/",
  "jobTitle": "Software and Web Engineer",
  "knowsAbout": ["Web Development", "SEO", "Software Engineering", "JavaScript", "React", "Node.js"],
  "offers": {
    "@type": "Service",
    "serviceType": "Web Development and SEO Services",
    "description": "Professional web development, SEO optimization, and software engineering services"
  },
  "sameAs": [
    "https://www.linkedin.com/in/john-wheeler-5697431b9/",
    "https://github.com/johnwheeler"
  ]
} : personSchema;

// ProfessionalService schema for homepage
const professionalServiceSchema = isHomepage ? {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "John Wheeler Production",
  "url": "https://www.johnwheelerproduction.com/",
  "description": "Professional web development and SEO services",
  "provider": {
    "@type": "Person",
    "name": "John Wheeler"
  },
  "serviceType": ["Web Development", "SEO Optimization", "Software Engineering"],
  "areaServed": "Worldwide"
} : null;

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "url": "https://www.johnwheelerproduction.com/",
  "name": "John Wheeler Production",
  "description": "Portfolio of John Wheeler"
};

// Blog schema for blog index page
const blogSchema = isBlogIndex ? {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "John Wheeler's Blog",
  "url": "https://www.johnwheelerproduction.com/blog/",
  "description": "Insights on web development, SEO, and technology",
  "author": {
    "@type": "Person",
    "name": "John Wheeler",
    "url": "https://www.johnwheelerproduction.com/"
  },
  "blogPost": blogPosts.map(post => ({
    "@type": "BlogPosting",
    "headline": post.title,
    "url": post.url,
    "datePublished": post.pubDate,
    "author": {
      "@type": "Person",
      "name": post.author || "John Wheeler"
    },
    "description": post.description
  }))
} : null;

// Generate breadcrumb schema if breadcrumbs are provided
const breadcrumbSchema = breadcrumbs ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((crumb, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": crumb.name,
    "item": crumb.url
  }))
} : null;

// Combine all schemas into an array for efficient rendering
const allSchemas: Record<string, any>[] = [enhancedPersonSchema, webSiteSchema];
if (professionalServiceSchema) allSchemas.push(professionalServiceSchema);
if (blogSchema) allSchemas.push(blogSchema);
if (breadcrumbSchema) allSchemas.push(breadcrumbSchema);
if (pageSchema) allSchemas.push(pageSchema);
if (faqSchema) allSchemas.push(faqSchema);
if (collectionSchema) allSchemas.push(collectionSchema);
---

<head>
  <LocalFont />
  <meta charset='utf-8' />
  <meta name='viewport' content='width=device-width, initial-scale=1' />
  <meta name='generator' content={Astro.generator} />

  <!-- Critical resource preloading for performance -->
  <link rel="dns-prefetch" href="https://www.googletagmanager.com">
  <link rel="preload" href="/favicon.svg" as="image" type="image/svg+xml">
  
  <!-- Google Tag Manager (deferred) -->
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });

    const loadGTM = () => {
      if (document.getElementById('gtm-script')) return;
      const gtmScript = document.createElement('script');
      gtmScript.id = 'gtm-script';
      gtmScript.async = true;
      gtmScript.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-5DFDJZF8';
      document.head.appendChild(gtmScript);
    };

    if ('requestIdleCallback' in window) {
      requestIdleCallback(loadGTM, { timeout: 2000 });
    } else {
      window.addEventListener('load', () => setTimeout(loadGTM, 1000), { once: true });
    }
  </script>
  <!-- End Google Tag Manager -->

  <link
    rel='alternate'
    href='https://johnwheelerproduction.com/feed.xml'
    type='application/rss+xml'
  />

  <meta name='title' content={`John Wheeler | ${title}`} />
  <meta name='description' content={description} />

  <meta property='og:type' content={ogType} />
  <meta property='og:url' content={canonicalURL} />
  <meta property='og:title' content={title} />
  <meta property='og:description' content={description} />
  <meta property='og:image' content={ogImage} />

  <meta property='twitter:card' content='summary_large_image' />
  <meta property='twitter:url' content={canonicalURL} />
  <meta property='twitter:title' content={title} />
  <meta property='twitter:description' content={description} />
  <meta property='twitter:image' content={ogImage} />

  <link rel='canonical' href={canonicalURL} />
  <link rel='icon' type='image/svg' href='/favicon.svg' />

  <title>John Wheeler | {title}</title>

<!-- Combined Schema Markup -->
<script type="application/ld+json" set:html={JSON.stringify(allSchemas)} is:inline></script>

  <slot />
</head>