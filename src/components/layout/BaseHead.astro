---
import LocalFont from '../generic/LocalFont.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: URL;
  ogType?: string;
  pageSchema?: Record<string, any>;
  breadcrumbs?: Array<{name: string, url: string}>;
  faqSchema?: Record<string, any> | null;
  collectionSchema?: Record<string, any>;
  isHomepage?: boolean;
  customTitle?: string;
  isBlogIndex?: boolean;
  blogPosts?: Array<{title: string, description: string, url: string, pubDate: string, author?: string}>;
  isTagPage?: boolean;
  tagName?: string;
  articleBody?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

if (Astro.props.ogImage === undefined) {
  Astro.props.ogImage = new URL('/v1/generate/og/default.png', Astro.url);
}

const { title, description, ogImage, ogType = 'website', pageSchema, breadcrumbs, faqSchema, collectionSchema, isHomepage = false, isBlogIndex = false, blogPosts = [], isTagPage = false, tagName } = Astro.props;

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "John Wheeler",
  "url": "https://www.johnwheelerproduction.com/",
  "jobTitle": "Web Developer & SEO/AEO Specialist",
  "knowsAbout": ["SEO", "AEO", "Web Development"],
  "sameAs": [
    "https://www.linkedin.com/in/john-wheeler-5697431b9/",
    "https://github.com/johnwheeler"
  ]
};

// Enhanced Person schema for homepage
const enhancedPersonSchema = isHomepage ? {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "John Wheeler",
  "url": "https://www.johnwheelerproduction.com/",
  "jobTitle": "Web Developer & SEO/AEO Specialist",
  "knowsAbout": ["SEO", "AEO", "Web Development", "JavaScript", "React", "Node.js"],
  "offers": {
    "@type": "Service",
    "serviceType": "Web Development and SEO Services",
    "description": "Professional web development, SEO optimization, and software engineering services"
  },
  "sameAs": [
    "https://www.linkedin.com/in/john-wheeler-5697431b9/",
    "https://github.com/johnwheeler"
  ]
} : personSchema;

// ProfessionalService schema for homepage
const professionalServiceSchema = isHomepage ? {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "John Wheeler Production",
  "url": "https://www.johnwheelerproduction.com/",
  "description": "Professional web development and SEO services",
  "provider": {
    "@type": "Person",
    "name": "John Wheeler"
  },
  "serviceType": ["Web Development", "SEO Optimization", "Software Engineering"],
  "areaServed": "Worldwide"
} : null;

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "url": "https://www.johnwheelerproduction.com/",
  "name": "John Wheeler Production",
  "description": "Portfolio of John Wheeler"
};

// Blog schema for blog index page
const blogSchema = isBlogIndex ? {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "John Wheeler's Blog",
  "url": "https://www.johnwheelerproduction.com/blog/",
  "description": "Insights on web development, SEO, and technology",
  "author": {
    "@type": "Person",
    "name": "John Wheeler",
    "url": "https://www.johnwheelerproduction.com/"
  },
  "blogPost": blogPosts.map(post => ({
    "@type": "BlogPosting",
    "headline": post.title,
    "url": post.url,
    "datePublished": post.pubDate,
    "author": {
      "@type": "Person",
      "name": post.author || "John Wheeler"
    },
    "description": post.description
  }))
} : null;

// CollectionPage schema for tag pages
const tagCollectionSchema = isTagPage && blogPosts.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `${tagName} - Blog Posts`,
  "url": canonicalURL.toString(),
  "description": `Collection of blog posts about ${tagName}`,
  "mainEntity": blogPosts.map(post => ({
    "@type": "BlogPosting",
    "headline": post.title,
    "url": post.url,
    "datePublished": post.pubDate,
    "author": {
      "@type": "Person",
      "name": post.author || "John Wheeler"
    },
    "description": post.description
  }))
} : null;

// Generate breadcrumb schema if breadcrumbs are provided
const breadcrumbSchema = breadcrumbs ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((crumb, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": crumb.name,
    "item": crumb.url
  }))
} : null;

// Combine all schemas into an array for efficient rendering
const allSchemas: Record<string, any>[] = [enhancedPersonSchema, webSiteSchema];
if (professionalServiceSchema) allSchemas.push(professionalServiceSchema);
if (blogSchema) allSchemas.push(blogSchema);
if (tagCollectionSchema) allSchemas.push(tagCollectionSchema);
if (breadcrumbSchema) allSchemas.push(breadcrumbSchema);
if (pageSchema) allSchemas.push(pageSchema);
if (faqSchema) allSchemas.push(faqSchema);
if (collectionSchema) allSchemas.push(collectionSchema);
---

<head>
  <LocalFont />
  <meta charset='utf-8' />
  <meta name='viewport' content='width=device-width, initial-scale=1' />
  <meta name='generator' content={Astro.generator} />

  <!-- Critical resource preloading for performance -->
  <link rel="dns-prefetch" href="https://www.googletagmanager.com">
  <link rel="preload" href="/favicon.svg" as="image" type="image/svg+xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  
  <!-- Critical CSS inlined to eliminate render blocking -->
  <style>
    /* Critical above-the-fold styles */
    html { height: 100%; }
    body { margin: 0; padding: 0; font-family: system-ui, -apple-system, sans-serif; }
    .hero-section { min-height: 50vh; }
    .nav-header { position: relative; z-index: 10; }
    /* Add other critical styles that affect LCP element */
  </style>
  
  <!-- Defer non-critical CSS -->
  <link rel="preload" href="/styles/global.css" as="style">
  <noscript><link rel="stylesheet" href="/styles/global.css"></noscript>
  
  <!-- Google Tag Manager (deferred further) -->
  <script is:inline>
    try {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });

      const loadGTM = () => {
        try {
          if (document.getElementById('gtm-script')) return;
          const gtmScript = document.createElement('script');
          gtmScript.id = 'gtm-script';
          gtmScript.async = true;
          gtmScript.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-5DFDJZF8';
          gtmScript.onerror = function() {
            console.warn('Failed to load Google Tag Manager');
          };
          document.head.appendChild(gtmScript);
        } catch (error) {
          console.warn('Error loading GTM:', error);
        }
      };

      // Delay GTM loading until after critical rendering
      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadGTM, { timeout: 3000 });
      } else {
        window.addEventListener('load', () => setTimeout(loadGTM, 2000), { once: true });
      }
    } catch (error) {
      console.warn('Error initializing GTM:', error);
    }
  </script>
  <!-- End Google Tag Manager -->

  <!-- HubSpot Tracking -->
  <script type="text/javascript" id="hs-script-loader" async defer src="//js.hs-scripts.com/51012416.js"></script>
  <!-- End HubSpot Tracking -->

  <link
    rel='alternate'
    href='https://johnwheelerproduction.com/feed.xml'
    type='application/rss+xml'
  />

  <meta name='title' content={`John Wheeler | ${title}`} />
  <meta name='description' content={description} />

  <meta property='og:type' content={ogType} />
  <meta property='og:url' content={canonicalURL} />
  <meta property='og:title' content={title} />
  <meta property='og:description' content={description} />
  <meta property='og:image' content={ogImage} />

  <meta property='twitter:card' content='summary_large_image' />
  <meta property='twitter:url' content={canonicalURL} />
  <meta property='twitter:title' content={title} />
  <meta property='twitter:description' content={description} />
  <meta property='twitter:image' content={ogImage} />

  <link rel='canonical' href={canonicalURL} />
  <link rel='icon' type='image/svg' href='/favicon.svg' />

  <title>John Wheeler | {title}</title>

<!-- Combined Schema Markup -->
<script type="application/ld+json" set:html={JSON.stringify(allSchemas)} is:inline></script>

  <slot />
</head>