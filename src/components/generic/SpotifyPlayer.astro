<div class="spotify-container">
  <h2 class="text-2xl md:text-4xl lg:text-6xl mb-4 dm-serif">
    What I'm listening to
  </h2>

  <div class="spotify-controls">
    <button id="spotify-prev" class="spotify-arrow" aria-label="Previous album">&#8592;</button>
    <div class="spotify-progress-wrap">
      <span id="spotify-count" class="spotify-count"></span>
      <div class="progress-track" aria-hidden="true">
        <div id="spotify-progress-fill" class="progress-fill"></div>
      </div>
    </div>
    <button id="spotify-next" class="spotify-arrow" aria-label="Next album">&#8594;</button>
  </div>

  <div class="spotify-content">
    <div class="current-album mb-6">
      <div class="iframe-wrap">
        <iframe
          id="spotify-frame"
          width="100%"
          height="352"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          title="Spotify album player"
          style="border: 0; border-radius: 12px; display: block;"
        ></iframe>
      </div>
      <div id="spotify-spinner" class="spotify-spinner" aria-label="Loading Spotify player" role="status">
        <div class="spinner-ring"></div>
      </div>
    </div>
  </div>
</div>

<script>
  type Album = { id: string };

  const albums: Album[] = [
    { id: '3hKlec1wgYVJcI0YvwCFJB' },
    { id: '5PKfMfQxsoapso8E9zu1A2' },
    { id: '1QZJzByKliJB2xyhgrYk4j' },
    { id: '3g4koxypokRF6kR3KA5F0P' },
    { id: '0U0Qv2jYtsgGxFDpQJKAxQ' },
    { id: '6kG4hK9mWCIzMdxOPciwe0' },
    { id: '0r5fbvh1kX0pJ4AFmRxiwd' },
  ];

  const CYCLE_MS = 8000;

  const frame    = document.getElementById('spotify-frame') as HTMLIFrameElement | null;
  const spinner  = document.getElementById('spotify-spinner');
  const fill     = document.getElementById('spotify-progress-fill');
  const countEl  = document.getElementById('spotify-count');
  const prevBtn  = document.getElementById('spotify-prev') as HTMLButtonElement | null;
  const nextBtn  = document.getElementById('spotify-next') as HTMLButtonElement | null;

  let currentIndex = 0;
  let progressStart = 0;
  let cycleTimer: ReturnType<typeof setTimeout> | null = null;
  let rafId: number | null = null;

  const updateCount = () => {
    if (countEl) countEl.textContent = `${currentIndex + 1} / ${albums.length}`;
  };

  const tickProgress = () => {
    if (!fill) return;
    const elapsed = Date.now() - progressStart;
    fill.style.width = `${Math.min((elapsed / CYCLE_MS) * 100, 100)}%`;
    rafId = requestAnimationFrame(tickProgress);
  };

  const resetProgress = () => {
    progressStart = Date.now();
  };

  const goTo = (index: number) => {
    currentIndex = (index + albums.length) % albums.length;
    const album = albums[currentIndex];
    if (!frame || !album) return;
    frame.src = `https://open.spotify.com/embed/album/${album.id}?utm_source=generator`;
    updateCount();
    resetProgress();
    scheduleCycle();
  };

  const scheduleCycle = () => {
    if (cycleTimer) clearTimeout(cycleTimer);
    if (albums.length > 1) {
      cycleTimer = setTimeout(() => goTo(currentIndex + 1), CYCLE_MS);
    }
  };

  const startPlayer = () => {
    goTo(0);

    frame?.addEventListener('load', () => spinner?.remove(), { once: true });

    if (rafId) cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(tickProgress);

    prevBtn?.addEventListener('click', () => goTo(currentIndex - 1));
    nextBtn?.addEventListener('click', () => goTo(currentIndex + 1));
  };

  document.addEventListener('DOMContentLoaded', startPlayer);
</script>

<style>
  .spotify-container {
    width: 100%;
  }

  .spotify-controls {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .spotify-arrow {
    background: #fff;
    border: 2px solid #000;
    border-radius: 0;
    width: 2.25rem;
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    flex-shrink: 0;
    box-shadow: 3px 3px 0 #000;
  }

  .spotify-arrow:hover {
    background: #000;
    color: #fff;
    box-shadow: 1px 1px 0 #000;
  }

  .spotify-progress-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .spotify-count {
    font-family: 'Poppins', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    color: #000;
    letter-spacing: 0.05em;
  }

  .progress-track {
    width: 100%;
    height: 4px;
    background: rgba(0, 0, 0, 0.35);
    border-radius: 0;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    width: 0%;
    background: #000;
    border-radius: 0;
  }

  .spotify-content {
    width: 100%;
  }

  .current-album {
    position: relative;
  }

  .iframe-wrap {
    border-radius: 14px;
    border: 2px solid #000;
    box-shadow: 6px 6px 0 #000;
    overflow: hidden;
  }

  .spotify-spinner {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    background: rgba(0, 0, 0, 0.05);
  }

  .spinner-ring {
    width: 40px;
    height: 40px;
    border: 4px solid rgba(0, 0, 0, 0.15);
    border-top-color: #000;
    border-radius: 50%;
    animation: spin 0.75s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>
